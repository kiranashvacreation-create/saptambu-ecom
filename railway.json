{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "preDeployCommand": "npm run railway:setup",
    "startCommand": "npm run start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300
  }
}
