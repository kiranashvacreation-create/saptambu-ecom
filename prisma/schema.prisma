generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  PARCELLED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum MediaStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DeliveryStatus {
  ORDER_PLACED
  PACKING
  PARCELLED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum EmailRecipientRole {
  CUSTOMER
  OWNER
}

enum EmailEvent {
  ORDER_CONFIRMATION
  OWNER_ORDER_NOTIFICATION
  DELIVERY_UPDATE
  OWNER_DELIVERY_UPDATE
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model Product {
  id                String             @id @default(cuid())
  title             String
  slug              String             @unique
  description       String             @default("")
  sku               String?
  price             Decimal            @db.Decimal(10, 2)
  salePrice         Decimal?           @db.Decimal(10, 2)
  compareAtPrice    Decimal?           @db.Decimal(10, 2)
  stock             Int                @default(0)
  lowStockThreshold Int                @default(5)
  status            ProductStatus      @default(ACTIVE)
  showWhenSoldOut   Boolean            @default(true)
  tags              String[]           @default([])
  images            ProductImage[]
  categories        ProductCategory[]
  orderItems        OrderItem[]
  stockAdjustments  StockAdjustment[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status])
  @@index([slug])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId])
}

model Category {
  id          String            @id @default(cuid())
  title       String
  slug        String            @unique
  description String            @default("")
  sortOrder   Int               @default(0)
  products    ProductCategory[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([slug])
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model DiscountCode {
  id              String       @id @default(cuid())
  code            String       @unique
  type            DiscountType
  value           Decimal      @db.Decimal(10, 2)
  isActive        Boolean      @default(true)
  minimumSubtotal Decimal?     @db.Decimal(10, 2)
  expiresAt       DateTime?
  maxUses         Int?
  perEmailLimit   Int?
  usedCount       Int          @default(0)
  orders          Order[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([code])
  @@index([isActive])
}

model Order {
  id                    String           @id @default(cuid())
  orderNumber           String           @unique
  customerName          String
  customerEmail         String
  customerPhone         String
  addressLine1          String
  addressLine2          String?
  city                  String
  state                 String
  pincode               String
  notes                 String?
  subtotal              Decimal          @db.Decimal(10, 2)
  discountTotal         Decimal          @default(0) @db.Decimal(10, 2)
  total                 Decimal          @db.Decimal(10, 2)
  status                OrderStatus      @default(PENDING_PAYMENT)
  paymentStatus         PaymentStatus    @default(PENDING)
  deliveryStatus        DeliveryStatus   @default(ORDER_PLACED)
  deliveryMessage       String?
  trackingUrl           String?
  awb                   String?
  razorpayOrderId       String?          @unique
  razorpayPaymentId     String?
  razorpaySignature     String?
  discountCodeId        String?
  discountCodeSnapshot  String?
  discountCode          DiscountCode?    @relation(fields: [discountCodeId], references: [id])
  items                 OrderItem[]
  deliveryUpdates       DeliveryUpdate[]
  emailLogs             EmailLog[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([customerEmail])
  @@index([status])
  @@index([paymentStatus])
  @@index([deliveryStatus])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String?
  productTitle String
  productSlug  String
  sku          String?
  unitPrice    Decimal  @db.Decimal(10, 2)
  quantity     Int
  lineTotal    Decimal  @db.Decimal(10, 2)
  imageUrl     String?
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model DeliveryUpdate {
  id        String         @id @default(cuid())
  orderId   String
  status    DeliveryStatus
  message   String
  emailed   Boolean        @default(false)
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  emailLogs EmailLog[]
  createdAt DateTime       @default(now())

  @@index([orderId])
}

model EmailLog {
  id               String             @id @default(cuid())
  recipient        String
  recipientRole    EmailRecipientRole
  event            EmailEvent
  subject          String
  status           EmailStatus        @default(PENDING)
  orderId          String?
  deliveryUpdateId String?
  error            String?
  sentAt           DateTime?
  createdAt        DateTime           @default(now())
  order            Order?             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryUpdate   DeliveryUpdate?    @relation(fields: [deliveryUpdateId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([deliveryUpdateId])
  @@index([event])
  @@index([status])
  @@index([createdAt])
}

model StockAdjustment {
  id        String   @id @default(cuid())
  productId String
  change    Int
  reason    String
  note      String?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String
  updatedAt DateTime @updatedAt
}

model MediaArticle {
  id             String      @id @default(cuid())
  title          String
  slug           String      @unique
  excerpt        String      @default("")
  bodyHtml       String      @default("")
  coverImageUrl  String?
  coverImageAlt  String?
  sourceName     String?
  sourceUrl      String?
  publishedAt    DateTime?
  sortOrder      Int         @default(0)
  status         MediaStatus @default(DRAFT)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status])
  @@index([slug])
  @@index([sortOrder])
}
